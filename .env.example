# AI Provider API Keys (добавьте хотя бы один, или оставьте пустым для fallback режима)

# Вариант 1: Google Gemini (основной, рекомендуется)
# Получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Вариант 2: Groq (бесплатный, резервный)
# Получить ключ: https://console.groq.com/keys
GROQ_API_KEY=

# Примечание: Приложение попробует провайдеры по порядку. Если все не работают, используется fallback контент.
